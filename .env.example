# =============================================================
# luma prototype — environment variables
# Copy this file to .env and fill in real keys.
# =============================================================

# --- Anthropic (Claude) ---
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Claude model. Recommended: claude-sonnet-4-6 (best quality + safety)
# Alternatives for cheaper: claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI (Whisper for voice transcription + embeddings for RAG) ---
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Twilio (WhatsApp messaging) ---
# Get from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Sandbox WhatsApp number (default for testing).
# In production, replace with your approved WhatsApp Business number.
# Format: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Server ---
# Port for local dev. Render/Fly inject their own PORT.
PORT=3000

# Public base URL of your deployed server (used for Twilio webhook + dashboard links)
# In dev: use ngrok or similar tunnel. In prod: your Render/Fly URL.
PUBLIC_BASE_URL=http://localhost:3000

# --- Optional ---
# Set to "true" to allow unsigned Twilio requests (only use during local dev)
ALLOW_UNSIGNED_REQUESTS=false

# Set to "true" to use mock LLM responses (no API key needed; used for tests)
USE_MOCK_APIS=false
