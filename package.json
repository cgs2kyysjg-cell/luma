{
  "name": "luma",
  "version": "0.1.0",
  "description": "luma — Ministry-licensed workflow infrastructure for community health, with pharma RWE as the data layer.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:prod": "node scripts/seed-demo-data.js && node server.js",
    "dev": "node --watch server.js",
    "ingest": "node src/ingest.js",
