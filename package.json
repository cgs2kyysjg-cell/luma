{
  "name": "luma",
  "version": "0.1.0",
  "description": "luma — AI-native services company replacing the INGO operational layer for community health in sub-Saharan Africa. Governments contract the service. Pharma F100 buys the data.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:prod": "node scripts/seed-demo-data.js && node scripts/seed-historical-data.js && node server.js",
    "dev": "node --watch server.js",
    "ingest": "node src/ingest.js",
    "seed": "node scripts/seed-demo-data.js",
    "seed:historical": "node scripts/seed-historical-data.js",
    "seed:historical:py": "python3 scripts/seed_historical_data.py",
    "test:claude": "node scripts/test-claude.js",
    "test:adversarial": "node scripts/test-adversarial.js",
    "setup": "bash scripts/setup.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "openai": "^4.67.0",
    "twilio": "^5.3.5"
  },
  "devDependencies": {}
}
