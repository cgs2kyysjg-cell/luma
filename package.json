    "test:adversarial": "node scripts/test-adversarial.js",
    "setup": "bash scripts/setup.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "openai": "^4.67.0",
    "twilio": "^5.3.5"
  },
  "devDependencies": {}
}
